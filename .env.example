# ─────────────────────────────────────────────────────────────────────────────
# HabitLab AI — Environment variable template.
# Copy this file to `.env` in the project root and fill in real values.
# `.env` is gitignored; `.env.example` is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://habitlab:habitlab_dev_password@localhost:5432/habitlab_dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_random_64_hex
JWT_REFRESH_SECRET=replace_me_with_different_random_64_hex
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
COOKIE_DOMAIN=localhost

# ── Email (transactional — Resend) ──────────────────────────────────────────
# Provider: https://resend.com — free tier: 3 000 emails/month.
# Leave RESEND_API_KEY blank to fall back to console logging (dev default).
# APP_URL is the frontend origin used to build verify/reset links.
# EMAIL_FROM must be a Resend-verified sender; use onboarding@resend.dev for
# testing before you verify a domain.
RESEND_API_KEY=
APP_URL=http://localhost:5173
EMAIL_FROM=HabitLab AI <onboarding@resend.dev>

# ── OpenAI (LLM provider) ───────────────────────────────────────────────────
# Not required until WP7. Leave blank during Phase 1 & Phase 2.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_DAILY_BUDGET_CENTS=300

# ── Web Push (VAPID) ────────────────────────────────────────────────────────
# Not required until WP9. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Frontend (Vite exposes VITE_* to the browser) ────────────────────────────
VITE_API_URL=http://localhost:3001/api/v1
