  "info": {
    "title": "HabitLab AI API",
    "description": "REST API for HabitLab AI. See docs/HabitLab_AI_Analysis_Report.docx §6.1.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "Min 8 chars, at least 1 letter and 1 digit"
          },
          "timezone": {
            "type": "string",
            "example": "Europe/Istanbul"
          },
          "locale": {
            "type": "string",
            "enum": [
              "en",
              "tr"
            ]
          },
          "consentGiven": {
            "type": "boolean",
            "description": "Must be true; false returns 400 CONSENT_REQUIRED"
          }
        },
        "required": [
          "email",
          "password",
          "timezone",
          "locale",
          "consentGiven"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "description": "Min 8 chars, at least 1 letter and 1 digit"
          }
        },
        "required": [
          "token",
          "newPassword"
        ]
      },
      "ChangePasswordDto": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "description": "Min 8 chars, at least 1 letter and 1 digit"
          }
        },
        "required": [
          "currentPassword",
          "newPassword"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "object",
            "example": "Alp",
            "maxLength": 100
          },
          "timezone": {
            "type": "string",
            "example": "Europe/Istanbul"
          },
          "locale": {
            "type": "string",
            "enum": [
              "en",
              "tr"
            ]
          },
          "experimentsOptedOut": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "CreateHabitDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "1–120 characters",
            "example": "Meditate 10 min"
          },
          "description": {
            "type": "object",
            "description": "Up to 500 characters"
          },
          "frequencyType": {
            "type": "string",
            "enum": [
              "daily",
              "weekly",
              "custom"
            ]
          },
          "weekdayMask": {
            "type": "object",
            "description": "Bit 0=Mon..bit 6=Sun; required when frequencyType=weekly",
            "example": 21
          },
          "targetCountPerWeek": {
            "type": "object",
            "description": "1–7; required when frequencyType=custom",
            "example": 3
          },
          "preferredTime": {
            "type": "object",
            "description": "HH:MM in user local time",
            "example": "07:00"
          },
          "difficulty": {
            "type": "number",
            "description": "1 (easy) .. 5 (hard)",
            "default": 3
          }
        },
        "required": [
          "name",
          "frequencyType"
        ]
      },
      "UpdateHabitDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "1–120 characters",
            "example": "Meditate 10 min"
          },
          "description": {
            "type": "object",
            "description": "Up to 500 characters"
          },
          "frequencyType": {
            "type": "string",
            "enum": [
              "daily",
              "weekly",
              "custom"
            ]
          },
          "weekdayMask": {
            "type": "object",
            "description": "Bit 0=Mon..bit 6=Sun; required when frequencyType=weekly",
            "example": 21
          },
          "targetCountPerWeek": {
            "type": "object",
            "description": "1–7; required when frequencyType=custom",
            "example": 3
          },
          "preferredTime": {
            "type": "object",
            "description": "HH:MM in user local time",
            "example": "07:00"
          },
          "difficulty": {
            "type": "number",
            "description": "1 (easy) .. 5 (hard)",
            "default": 3
          },
          "isActive": {
            "type": "boolean"
          }
        }
      },
      "LogHabitDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "skipped"
            ]
          },
          "date": {
            "type": "string",
            "description": "YYYY-MM-DD; defaults to today in user's timezone",
            "example": "2026-04-22"
          },
          "note": {
            "type": "string",
            "description": "Max 500 characters"
          }
        },
        "required": [
          "status"
        ]
      },
      "UpdateLogDto": {
        "type": "object",
        "properties": {
          "note": {
            "type": "string",
            "description": "Max 500 characters"
          }
        },
        "required": [
          "note"
        ]
      },
      "PushKeysDto": {
        "type": "object",
        "properties": {
          "p256dh": {
            "type": "string",
            "description": "P-256 DH public key from the push subscription"
          },
          "auth": {
            "type": "string",
            "description": "Auth secret from the push subscription"
          }
        },
        "required": [
          "p256dh",
          "auth"
        ]
      },
      "SubscribeDto": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string",
            "description": "Push endpoint URL from the browser PushSubscription"
          },
          "keys": {
            "$ref": "#/components/schemas/PushKeysDto"
          },
          "userAgent": {
            "type": "string"
          }
        },
        "required": [
          "endpoint",
          "keys"
        ]
      }
    }
  }
}
